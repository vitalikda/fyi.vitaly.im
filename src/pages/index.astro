---
import Layout from "../layouts/Layout.astro";
import BrowserInfo from "../components/browser-info.tsx";
---
<Layout title="Browser Info — FYI" description="View your browser and device information.">
  <main class="container mx-auto px-4 py-6 max-w-4xl">
    <header class="text-center mb-4">
      <h1 class="text-2xl font-bold text-primary mb-1">Browser Info</h1>
      <p class="text-base-content/70 text-sm">Client-side browser and device details</p>
    </header>
    <BrowserInfo client:only="preact" />
  </main>
</Layout>
